<!DOCTYPE html>
<html class="dark" lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="TechNexus - Your Gateway to Exciting Tech Events and Hackathons">
  <title><%= title || 'TechNexus' %></title>

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/images/react.svg">

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">

  <!-- Tailwind CSS -->
  <link href="/stylesheets/main.css" rel="stylesheet">

  <!-- SweetAlert2 -->
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <% if (typeof additionalStyles !== 'undefined') { %>
    <% additionalStyles.forEach(style => { %>
      <link href="<%= style %>" rel="stylesheet">
    <% }) %>
  <% } %>

  <style>
    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      display: inline-block;
      vertical-align: middle;
    }

    body {
      background-color: #0b1326;
      color: #dae2fd;
      -webkit-font-smoothing: antialiased;
    }

    /* Custom scrollbar */
    ::-webkit-scrollbar { width: 8px; }
    ::-webkit-scrollbar-track { background: #060e20; }
    ::-webkit-scrollbar-thumb { background: #2d3449; border-radius: 4px; }
    ::-webkit-scrollbar-thumb:hover { background: #464554; }

    .glass-card {
      background: rgba(30, 41, 59, 0.7);
      backdrop-filter: blur(12px);
      border: 1px solid #334155;
    }

    .tonal-layer-1 {
      background-color: #1E293B;
      border: 1px solid #334155;
    }

    .tonal-layer-2 {
      background-color: #334155;
      box-shadow: 0 16px 32px -8px rgba(0,0,0,0.4);
    }

    .chart-bar {
      transition: height 1s ease-out;
    }
  </style>
</head>
<body class="font-body-md text-body-md overflow-x-hidden">
  <!-- Navigation -->
  <%- include('../partials/header') %>

  <!-- Mobile Menu -->
  <%- include('../partials/mobile-menu') %>

  <!-- Main Content -->
  <main class="flex-1">
    <%- content %>
  </main>

  <!-- Footer -->
  <%- include('../partials/footer') %>

  <!-- Scripts -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

  <% if (typeof additionalScripts !== 'undefined') { %>
    <% additionalScripts.forEach(script => { %>
      <script src="<%= script %>"></script>
    <% }) %>
  <% } %>

  <script>
    // Mobile Menu Toggle
    const mobileMenuButton = document.getElementById('mobile-menu-button');
    const mobileMenu = document.getElementById('mobile-menu');

    if (mobileMenuButton && mobileMenu) {
      mobileMenuButton.addEventListener('click', () => {
        mobileMenu.classList.toggle('hidden');
        document.body.classList.toggle('overflow-hidden');
      });

      // Close menu on link click
      mobileMenu.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          mobileMenu.classList.add('hidden');
          document.body.classList.remove('overflow-hidden');
        });
      });
    }

    // Smooth scroll for anchor links
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function (e) {
        e.preventDefault();
        const target = document.querySelector(this.getAttribute('href'));
        if (target) {
          target.scrollIntoView({ behavior: 'smooth' });
        }
      });
    });

    // Micro-interactions for buttons
    document.querySelectorAll('button').forEach(btn => {
      btn.addEventListener('mousedown', () => {
        btn.style.transform = 'scale(0.97)';
      });
      btn.addEventListener('mouseup', () => {
        btn.style.transform = '';
      });
      btn.addEventListener('mouseleave', () => {
        btn.style.transform = '';
      });
    });

    // Scroll effects for navigation
    window.addEventListener('scroll', () => {
      const nav = document.querySelector('nav');
      if (window.scrollY > 50) {
        nav.classList.add('tonal-layer-2');
        nav.classList.remove('bg-surface-container-low');
      } else {
        nav.classList.remove('tonal-layer-2');
        nav.classList.add('bg-surface-container-low');
      }
    });
  </script>

  <% if (typeof pageScripts !== 'undefined') { %>
    <% pageScripts.forEach(script => { %>
      <%- script %>
    <% }) %>
  <% } %>
<script src="https://www.noupe.com/embed/019f0710910b7c24bb248d0bee6442ee0030.js"></script>
</body>
</html>
