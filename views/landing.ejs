<!DOCTYPE html>
<html class="dark" lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>TechNexus | Discover Technical Hackathons & Events</title>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <script>
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            "primary-fixed-dim": "#c0c1ff",
            "inverse-surface": "#dae2fd",
            "tertiary-container": "#00885d",
            "tertiary": "#4edea3",
            "primary-container": "#8083ff",
            "on-primary-fixed": "#07006c",
            "surface-container": "#171f33",
            "surface-tint": "#c0c1ff",
            "on-primary-fixed-variant": "#2f2ebe",
            "background": "#0b1326",
            "surface-container-lowest": "#060e20",
            "on-tertiary-fixed": "#002113",
            "surface-container-low": "#131b2e",
            "surface-bright": "#31394d",
            "outline-variant": "#464554",
            "surface-container-high": "#222a3d",
            "inverse-on-surface": "#283044",
            "on-error-container": "#ffdad6",
            "surface-container-highest": "#2d3449",
            "surface-dim": "#0b1326",
            "on-secondary-container": "#e6ecff",
            "on-secondary-fixed": "#001a42",
            "secondary-fixed-dim": "#adc6ff",
            "secondary-fixed": "#d8e2ff",
            "on-secondary": "#002e6a",
            "outline": "#908fa0",
            "on-tertiary-fixed-variant": "#005236",
            "on-tertiary": "#003824",
            "error": "#ffb4ab",
            "on-surface": "#dae2fd",
            "tertiary-fixed-dim": "#4edea3",
            "on-error": "#690005",
            "on-primary-container": "#0d0096",
            "on-surface-variant": "#c7c4d7",
            "error-container": "#93000a",
            "on-background": "#dae2fd",
            "surface-variant": "#2d3449",
            "surface": "#0b1326",
            "primary": "#c0c1ff",
            "inverse-primary": "#494bd6",
            "on-secondary-fixed-variant": "#004395",
            "on-tertiary-container": "#000703",
            "primary-fixed": "#e1e0ff",
            "secondary-container": "#0566d9",
            "secondary": "#adc6ff",
            "tertiary-fixed": "#6ffbbe",
            "on-primary": "#1000a9"
          },
          borderRadius: {
            "DEFAULT": "0.125rem",
            "lg": "0.25rem",
            "xl": "0.5rem",
            "full": "0.75rem"
          },
          spacing: {
            "gutter": "24px",
            "stack-sm": "8px",
            "margin-mobile": "16px",
            "margin-desktop": "48px",
            "stack-md": "16px",
            "base-unit": "4px",
            "container-max": "1280px",
            "stack-lg": "32px"
          },
          fontFamily: {
            "headline-lg-mobile": ["Inter"],
            "body-sm": ["Inter"],
            "button-text": ["Inter"],
            "body-md": ["Inter"],
            "headline-lg": ["Inter"],
            "label-mono": ["JetBrains Mono"],
            "headline-xl": ["Inter"],
            "body-lg": ["Inter"],
            "headline-md": ["Inter"]
          },
          fontSize: {
            "headline-lg-mobile": ["24px", { "lineHeight": "32px", "letterSpacing": "-0.01em", "fontWeight": "700" }],
            "body-sm": ["14px", { "lineHeight": "20px", "fontWeight": "400" }],
            "button-text": ["15px", { "lineHeight": "16px", "fontWeight": "600" }],
            "body-md": ["16px", { "lineHeight": "24px", "fontWeight": "400" }],
            "headline-lg": ["32px", { "lineHeight": "40px", "letterSpacing": "-0.02em", "fontWeight": "700" }],
            "label-mono": ["13px", { "lineHeight": "16px", "letterSpacing": "0.05em", "fontWeight": "500" }],
            "headline-xl": ["48px", { "lineHeight": "56px", "letterSpacing": "-0.02em", "fontWeight": "700" }],
            "body-lg": ["18px", { "lineHeight": "28px", "fontWeight": "400" }],
            "headline-md": ["24px", { "lineHeight": "32px", "fontWeight": "600" }]
          }
        }
      }
    }
  </script>

  <style>
    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      display: inline-block;
      vertical-align: middle;
    }

    body {
      background-color: #0b1326;
      color: #dae2fd;
      -webkit-font-smoothing: antialiased;
    }

    /* Custom scrollbar */
    ::-webkit-scrollbar { width: 8px; }
    ::-webkit-scrollbar-track { background: #060e20; }
    ::-webkit-scrollbar-thumb { background: #2d3449; border-radius: 4px; }
    ::-webkit-scrollbar-thumb:hover { background: #464554; }

    .tonal-layer-1 { background-color: #1E293B; border: 1px solid #334155; }
    .tonal-layer-2 { background-color: #334155; box-shadow: 0 16px 32px -8px rgba(0,0,0,0.4); }
  </style>
</head>

<body class="font-body-md text-body-md overflow-x-hidden">
  <!-- TopNavBar -->
  <nav class="bg-surface-container-low dark:bg-surface-container-low border-b border-outline-variant dark:border-outline-variant docked full-width top-0 sticky z-50">
    <div class="flex justify-between items-center w-full px-margin-desktop max-w-container-max mx-auto h-16">
      <div class="flex items-center gap-stack-lg">
        <span class="text-headline-md font-headline-md font-bold text-primary dark:text-primary">TechNexus</span>
        <div class="hidden md:flex gap-stack-md">
          <a class="text-primary dark:text-primary font-bold border-b-2 border-primary pb-1 font-label-mono text-label-mono transition-colors" href="#events">Events</a>
          <a class="text-on-surface-variant dark:text-on-surface-variant font-medium hover:text-primary dark:hover:text-primary-fixed-dim transition-colors font-label-mono text-label-mono" href="#hackathons">Hackathons</a>
        </div>
      </div>

      <div class="flex items-center gap-stack-md">
        <div class="hidden md:flex items-center bg-surface-container-high rounded-full px-4 py-1.5 border border-outline-variant">
          <span class="material-symbols-outlined text-on-surface-variant text-[18px]">search</span>
          <input class="bg-transparent border-none focus:ring-0 text-body-sm placeholder:text-on-surface-variant w-48" placeholder="Search events..." type="text"/>
        </div>

        <% if (isAuthenticated) { %>
          <a href="/dashboard" class="text-on-surface-variant font-medium hover:text-primary transition-colors px-4 py-2 font-button-text text-button-text">Dashboard</a>
        <% } else { %>
          <a href="/signin" class="text-on-surface-variant font-medium hover:text-primary transition-colors px-4 py-2 font-button-text text-button-text">Sign In</a>
          <a href="/signup" class="bg-primary text-on-primary font-bold px-6 py-2 rounded-lg hover:opacity-90 transition-all font-button-text text-button-text">Sign Up</a>
        <% } %>
      </div>
    </div>
  </nav>

  <main>
    <!-- Hero Section -->
    <section class="relative min-h-[870px] flex items-center overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-background/0 via-background/60 to-background"></div>
      <div class="relative w-full max-w-container-max mx-auto px-margin-desktop py-stack-lg">
        <div class="max-w-3xl">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 border border-primary/20 mb-stack-md">
            <span class="w-2 h-2 rounded-full bg-tertiary animate-pulse"></span>
            <span class="font-label-mono text-label-mono text-primary tracking-wider uppercase">Live Platform 2.0</span>
          </div>

          <h1 class="font-headline-xl text-headline-xl text-on-surface mb-stack-md leading-tight">
            Engineer the Future at <span class="text-primary">Global Scale.</span>
          </h1>

          <p class="font-body-lg text-body-lg text-on-surface-variant mb-stack-lg max-w-xl">
            Connect with top-tier technical challenges, elite hackathons, and high-performance developer communities. Your next career-defining breakthrough starts here.
          </p>

          <div class="flex flex-wrap gap-stack-md">
            <a href="/events" class="bg-primary text-on-primary font-bold px-8 py-4 rounded-xl flex items-center gap-2 group transition-all hover:shadow-[0_0_20px_rgba(192,193,255,0.3)]">
              <span class="font-button-text text-button-text">Explore Hackathons</span>
              <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">arrow_forward</span>
            </a>
            <% if (!isAuthenticated) { %>
              <a href="/signup" class="border border-outline-variant bg-surface-container-low hover:bg-surface-container-high text-on-surface font-bold px-8 py-4 rounded-xl transition-all">
                <span class="font-button-text text-button-text">Create Account</span>
              </a>
            <% } %>
          </div>

          <div class="mt-stack-lg flex items-center gap-8 border-t border-outline-variant/30 pt-stack-lg">
            <div>
              <p class="font-headline-md text-headline-md text-primary">500+</p>
              <p class="font-label-mono text-label-mono text-on-surface-variant uppercase">Hackathons</p>
            </div>
            <div class="w-px h-10 bg-outline-variant/30"></div>
            <div>
              <p class="font-headline-md text-headline-md text-primary">120k</p>
              <p class="font-label-mono text-label-mono text-on-surface-variant uppercase">Developers</p>
            </div>
            <div class="w-px h-10 bg-outline-variant/30"></div>
            <div>
              <p class="font-headline-md text-headline-md text-primary">$4.2M</p>
              <p class="font-label-mono text-label-mono text-on-surface-variant uppercase">Prize Pools</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Features Bento Grid -->
    <section class="py-stack-lg w-full max-w-container-max mx-auto px-margin-desktop" id="features">
      <div class="flex flex-col md:flex-row justify-between items-end mb-stack-lg gap-stack-md">
        <div class="max-w-xl">
          <h2 class="font-headline-lg text-headline-lg mb-stack-sm">Why Elite Developers Choose TechNexus</h2>
          <p class="text-on-surface-variant">A specialized infrastructure designed to bridge the gap between technical talent and high-stakes innovation.</p>
        </div>
        <a href="#" class="text-primary font-label-mono text-label-mono uppercase tracking-widest flex items-center gap-2 hover:underline">
          View Platform Specs <span class="material-symbols-outlined">north_east</span>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-12 grid-rows-2 gap-gutter min-h-[600px]">
        <!-- Feature 1: Large -->
        <div class="md:col-span-8 md:row-span-1 tonal-layer-1 rounded-xl p-8 relative overflow-hidden group">
          <div class="relative z-10 max-w-md">
            <span class="material-symbols-outlined text-primary text-4xl mb-4">terminal</span>
            <h3 class="font-headline-md text-headline-md mb-2">Automated Code Validation</h3>
            <p class="text-on-surface-variant">Proprietary scoring engine that evaluates submissions based on performance, security, and scalability metrics in real-time.</p>
          </div>
        </div>

        <!-- Feature 2: Small -->
        <div class="md:col-span-4 md:row-span-1 tonal-layer-1 rounded-xl p-8 flex flex-col justify-between border-tertiary/20">
          <div>
            <span class="material-symbols-outlined text-tertiary text-3xl mb-4">hub</span>
            <h3 class="font-headline-md text-headline-md mb-2">Smart Matchmaking</h3>
          </div>
          <p class="text-on-surface-variant text-body-sm">AI-driven team formation based on tech stacks, timezones, and competitive history.</p>
        </div>

        <!-- Feature 3: Small -->
        <div class="md:col-span-4 md:row-span-1 tonal-layer-1 rounded-xl p-8 border-secondary/20">
          <span class="material-symbols-outlined text-secondary text-3xl mb-4">payments</span>
          <h3 class="font-headline-md text-headline-md mb-2">Instant Prize Payouts</h3>
          <p class="text-on-surface-variant text-body-sm">Automated smart-contract escrow systems ensuring winners receive prizes within 24 hours of judging completion.</p>
        </div>

        <!-- Feature 4: Large -->
        <div class="md:col-span-8 md:row-span-1 tonal-layer-1 rounded-xl p-8 flex items-center gap-8 relative overflow-hidden">
          <div class="flex-1">
            <h3 class="font-headline-md text-headline-md mb-2">Global Partner Network</h3>
            <p class="text-on-surface-variant mb-6">Gain direct access to recruitment pipelines from Fortune 500 tech giants and unicorn startups during every event.</p>
            <div class="flex gap-4 opacity-50">
              <div class="w-12 h-12 bg-surface-container-highest rounded-lg"></div>
              <div class="w-12 h-12 bg-surface-container-highest rounded-lg"></div>
              <div class="w-12 h-12 bg-surface-container-highest rounded-lg"></div>
              <div class="w-12 h-12 bg-surface-container-highest rounded-lg"></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Events Showcase -->
    <section class="py-stack-lg bg-surface-container-lowest" id="events">
      <div class="max-w-container-max mx-auto px-margin-desktop">
        <div class="flex items-center justify-between mb-stack-lg">
          <h2 class="font-headline-lg text-headline-lg">Featured Opportunities</h2>
          <div class="flex gap-2">
            <a href="/events" class="text-primary font-label-mono text-label-mono uppercase tracking-widest border border-outline-variant px-6 py-3 rounded-lg hover:bg-surface-container-high transition-all">
              View All Events
            </a>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-gutter">
          <!-- Event Card 1 -->
          <div class="tonal-layer-1 rounded-xl overflow-hidden flex flex-col group cursor-pointer hover:border-primary/50 transition-all">
            <div class="h-48 w-full relative bg-surface-container-highest">
              <div class="absolute top-4 right-4 bg-background/80 backdrop-blur-md px-3 py-1 rounded-lg border border-outline-variant">
                <span class="font-label-mono text-label-mono text-primary">$50,000</span>
              </div>
              <div class="absolute inset-0 flex items-center justify-center">
                <span class="material-symbols-outlined text-6xl text-on-surface-variant/30">code</span>
              </div>
            </div>
            <div class="p-6 flex-1 flex flex-col">
              <div class="flex gap-2 mb-3">
                <span class="font-label-mono text-[10px] uppercase bg-primary/10 text-primary px-2 py-0.5 rounded border border-primary/20">AI & ML</span>
                <span class="font-label-mono text-[10px] uppercase bg-tertiary/10 text-tertiary px-2 py-0.5 rounded border border-tertiary/20">Online</span>
              </div>
              <h4 class="font-headline-md text-headline-md mb-2 group-hover:text-primary transition-colors">NeuralNexus: Global AI Summit</h4>
              <p class="text-on-surface-variant text-body-sm mb-6 line-clamp-2">Build the next generation of autonomous agents using LLMs and transformer architectures.</p>
              <div class="mt-auto pt-4 border-t border-outline-variant/30 flex justify-between items-center">
                <div class="flex items-center gap-2">
                  <span class="material-symbols-outlined text-on-surface-variant text-[18px]">calendar_today</span>
                  <span class="font-label-mono text-label-mono text-on-surface-variant">Oct 12</span>
                </div>
                <span class="font-label-mono text-label-mono text-on-surface-variant">842 Joined</span>
              </div>
            </div>
          </div>

          <!-- Event Card 2 -->
          <div class="tonal-layer-1 rounded-xl overflow-hidden flex flex-col group cursor-pointer hover:border-primary/50 transition-all">
            <div class="h-48 w-full relative bg-surface-container-highest">
              <div class="absolute top-4 right-4 bg-background/80 backdrop-blur-md px-3 py-1 rounded-lg border border-outline-variant">
                <span class="font-label-mono text-label-mono text-primary">$120,000</span>
              </div>
              <div class="absolute inset-0 flex items-center justify-center">
                <span class="material-symbols-outlined text-6xl text-on-surface-variant/30">currency_bitcoin</span>
              </div>
            </div>
            <div class="p-6 flex-1 flex flex-col">
              <div class="flex gap-2 mb-3">
                <span class="font-label-mono text-[10px] uppercase bg-primary/10 text-primary px-2 py-0.5 rounded border border-primary/20">Web3</span>
                <span class="font-label-mono text-[10px] uppercase bg-tertiary/10 text-tertiary px-2 py-0.5 rounded border border-tertiary/20">Hybrid</span>
              </div>
              <h4 class="font-headline-md text-headline-md mb-2 group-hover:text-primary transition-colors">ChainReaction Hack 2024</h4>
              <p class="text-on-surface-variant text-body-sm mb-6 line-clamp-2">Architecting secure, decentralized protocols for the next web. Focus on Zero-Knowledge proofs.</p>
              <div class="mt-auto pt-4 border-t border-outline-variant/30 flex justify-between items-center">
                <div class="flex items-center gap-2">
                  <span class="material-symbols-outlined text-on-surface-variant text-[18px]">calendar_today</span>
                  <span class="font-label-mono text-label-mono text-on-surface-variant">Ends in 2d 4h</span>
                </div>
                <span class="font-label-mono text-label-mono text-error">Filling Fast</span>
              </div>
            </div>
          </div>

          <!-- Event Card 3 -->
          <div class="tonal-layer-1 rounded-xl overflow-hidden flex flex-col group cursor-pointer hover:border-primary/50 transition-all">
            <div class="h-48 w-full relative bg-surface-container-highest">
              <div class="absolute top-4 right-4 bg-background/80 backdrop-blur-md px-3 py-1 rounded-lg border border-outline-variant">
                <span class="font-label-mono text-label-mono text-primary">Hire Grants</span>
              </div>
              <div class="absolute inset-0 flex items-center justify-center">
                <span class="material-symbols-outlined text-6xl text-on-surface-variant/30">cloud</span>
              </div>
            </div>
            <div class="p-6 flex-1 flex flex-col">
              <div class="flex gap-2 mb-3">
                <span class="font-label-mono text-[10px] uppercase bg-primary/10 text-primary px-2 py-0.5 rounded border border-primary/20">DevOps</span>
                <span class="font-label-mono text-[10px] uppercase bg-tertiary/10 text-tertiary px-2 py-0.5 rounded border border-tertiary/20">In-Person</span>
              </div>
              <h4 class="font-headline-md text-headline-md mb-2 group-hover:text-primary transition-colors">CloudScale Architecture Expo</h4>
              <p class="text-on-surface-variant text-body-sm mb-6 line-clamp-2">Design resilient cloud-native infrastructures. Direct recruitment event for top infrastructure teams.</p>
              <div class="mt-auto pt-4 border-t border-outline-variant/30 flex justify-between items-center">
                <div class="flex items-center gap-2">
                  <span class="material-symbols-outlined text-on-surface-variant text-[18px]">location_on</span>
                  <span class="font-label-mono text-label-mono text-on-surface-variant">San Francisco</span>
                </div>
                <span class="font-label-mono text-label-mono text-on-surface-variant">25 Slots Left</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-stack-lg relative overflow-hidden">
      <div class="max-w-container-max mx-auto px-margin-desktop">
        <div class="bg-primary rounded-2xl p-12 relative overflow-hidden flex flex-col md:flex-row items-center gap-12">
          <div class="relative z-10 text-center md:text-left flex-1">
            <h2 class="font-headline-xl text-headline-xl text-on-primary mb-4 leading-tight">Ready to prove your <br/>technical edge?</h2>
            <p class="text-on-primary-container text-body-lg mb-8 max-w-lg">Join the world's most talented developers and engineers. Build projects that matter and get rewarded for your skills.</p>
            <div class="flex flex-wrap justify-center md:justify-start gap-4">
              <% if (isAuthenticated) { %>
                <a href="/events" class="bg-on-primary text-primary font-bold px-8 py-4 rounded-xl font-button-text text-button-text hover:shadow-lg transition-all">Browse Events</a>
              <% } else { %>
                <a href="/signup" class="bg-on-primary text-primary font-bold px-8 py-4 rounded-xl font-button-text text-button-text hover:shadow-lg transition-all">Create Free Account</a>
              <% } %>
            </div>
          </div>
          <!-- Decorative background shapes -->
          <div class="absolute -right-20 -top-20 w-64 h-64 bg-on-primary opacity-10 rounded-full blur-3xl"></div>
        </div>
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer class="bg-surface-container-lowest dark:bg-surface-container-lowest border-t border-outline-variant dark:border-outline-variant">
    <div class="w-full py-stack-lg px-margin-desktop grid grid-cols-1 md:grid-cols-4 gap-gutter max-w-container-max mx-auto">
      <div class="flex flex-col gap-4">
        <span class="font-headline-md text-headline-md text-primary dark:text-primary">TechNexus</span>
        <p class="font-body-sm text-body-sm text-on-surface-variant">The premier infrastructure for global technical hackathons and developer event management.</p>
        <div class="flex gap-4 mt-2">
          <a class="text-on-surface-variant hover:text-primary transition-colors" href="#">
            <span class="material-symbols-outlined">public</span>
          </a>
          <a class="text-on-surface-variant hover:text-primary transition-colors" href="#">
            <span class="material-symbols-outlined">code</span>
          </a>
          <a class="text-on-surface-variant hover:text-primary transition-colors" href="#">
            <span class="material-symbols-outlined">alternate_email</span>
          </a>
        </div>
      </div>

      <div class="flex flex-col gap-4">
        <h4 class="font-label-mono text-label-mono text-on-surface font-bold uppercase tracking-widest">Platform</h4>
        <ul class="flex flex-col gap-2">
          <li><a class="text-on-surface-variant hover:text-primary transition-colors font-body-sm text-body-sm" href="/events">Browse Events</a></li>
          <li><a class="text-on-surface-variant hover:text-primary transition-colors font-body-sm text-body-sm" href="/hackathons">Hackathons</a></li>
          <li><a class="text-on-surface-variant hover:text-primary transition-colors font-body-sm text-body-sm" href="/pastEvents">Past Events</a></li>
          <li><a class="text-on-surface-variant hover:text-primary transition-colors font-body-sm text-body-sm" href="/pastHackathons">Past Hackathons</a></li>
        </ul>
      </div>

      <div class="flex flex-col gap-4">
        <h4 class="font-label-mono text-label-mono text-on-surface font-bold uppercase tracking-widest">Support</h4>
        <ul class="flex flex-col gap-2">
          <li><a class="text-on-surface-variant hover:text-primary transition-colors font-body-sm text-body-sm" href="#">Documentation</a></li>
          <li><a class="text-on-surface-variant hover:text-primary transition-colors font-body-sm text-body-sm" href="#">Contact Support</a></li>
          <li><a class="text-on-surface-variant hover:text-primary transition-colors font-body-sm text-body-sm" href="#">System Status</a></li>
        </ul>
      </div>

      <div class="flex flex-col gap-4">
        <h4 class="font-label-mono text-label-mono text-on-surface font-bold uppercase tracking-widest">Stay Updated</h4>
        <p class="text-on-surface-variant text-body-sm">Get the latest events and opportunities delivered to your inbox.</p>
        <form action="/subscribe" method="POST" class="flex flex-col gap-2">
          <input class="bg-background border-outline-variant rounded-lg px-4 py-2 text-on-surface focus:ring-2 focus:ring-primary outline-none text-body-sm" placeholder="Enter your email" type="email" name="email" required>
          <button type="submit" class="bg-primary text-on-primary px-4 py-2 rounded-lg font-button-text text-button-text transition-all active:scale-95 text-sm">Subscribe</button>
        </form>
      </div>
    </div>

    <div class="w-full py-6 px-margin-desktop border-t border-outline-variant/10 max-w-container-max mx-auto flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="font-label-mono text-label-mono text-on-surface-variant opacity-60">© 2024 TechNexus Hackathon Platform. All rights reserved.</p>
      <div class="flex items-center gap-2">
        <div class="w-2 h-2 rounded-full bg-tertiary"></div>
        <span class="font-label-mono text-label-mono text-tertiary text-[10px] uppercase">All Systems Operational</span>
      </div>
    </div>
  </footer>

  <script>
    // Newsletter form submission
    document.querySelector('form[action="/subscribe"]').addEventListener('submit', function (e) {
      e.preventDefault();
      const email = this.querySelector('input[name="email"]').value;

      fetch('/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: email }),
      })
        .then(response => response.json())
        .then(data => {
          if (data.status === 'success') {
            Swal.fire('Subscribed!', 'You have successfully subscribed to our newsletter.', 'success').then(() => {
              this.querySelector('input[name="email"]').value = '';
            });
          }
        })
        .catch(error => {
          Swal.fire('Error', 'Failed to subscribe. Please try again.', 'error');
        });
    });

    // Scroll effects for navigation
    window.addEventListener('scroll', () => {
      const nav = document.querySelector('nav');
      if (window.scrollY > 50) {
        nav.classList.add('tonal-layer-2');
        nav.classList.remove('bg-surface-container-low');
      } else {
        nav.classList.remove('tonal-layer-2');
        nav.classList.add('bg-surface-container-low');
      }
    });

    // Micro-interactions for buttons
    document.querySelectorAll('button, a').forEach(btn => {
      btn.addEventListener('mousedown', () => {
        btn.style.transform = 'scale(0.97)';
      });
      btn.addEventListener('mouseup', () => {
        btn.style.transform = '';
      });
      btn.addEventListener('mouseleave', () => {
        btn.style.transform = '';
      });
    });
  </script>
<script src="https://www.noupe.com/embed/019f0710910b7c24bb248d0bee6442ee0030.js"></script>
</body>
</html>
