<%-
layout('auth-layout', {
  title: 'Verify OTP - Student Corner',
  heading: 'Enter Verification Code',
  subheading: 'We sent a code to your email or phone. Enter it below to verify.'
})
-%>

<div class="animate-fade-in">
  <!-- Form Header -->
  <div class="mb-8 text-center">
    <h2 class="text-2xl font-bold text-secondary-900 dark:text-white">Verify Code</h2>
    <p class="mt-2 text-sm text-secondary-600 dark:text-secondary-400">
      Enter the 6-digit code sent to
      <span class="font-medium text-secondary-900 dark:text-white">
        <%= typeof identifier !== 'undefined' ? identifier : 'your email or phone' %>
      </span>
    </p>
  </div>

  <!-- OTP Form -->
  <form id="otp-form" class="space-y-6">
    <!-- OTP Input Container -->
    <div class="flex justify-center gap-2">
      <input
        type="text"
        maxlength="1"
        class="otp-input w-12 h-14 text-center text-2xl font-bold rounded-lg border border-secondary-300 bg-white text-secondary-900 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 dark:border-secondary-700 dark:bg-secondary-800 dark:text-white"
        required
        autocomplete="off"
      >
      <input
        type="text"
        maxlength="1"
        class="otp-input w-12 h-14 text-center text-2xl font-bold rounded-lg border border-secondary-300 bg-white text-secondary-900 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 dark:border-secondary-700 dark:bg-secondary-800 dark:text-white"
        required
        autocomplete="off"
      >
      <input
        type="text"
        maxlength="1"
        class="otp-input w-12 h-14 text-center text-2xl font-bold rounded-lg border border-secondary-300 bg-white text-secondary-900 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 dark:border-secondary-700 dark:bg-secondary-800 dark:text-white"
        required
        autocomplete="off"
      >
      <input
        type="text"
        maxlength="1"
        class="otp-input w-12 h-14 text-center text-2xl font-bold rounded-lg border border-secondary-300 bg-white text-secondary-900 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 dark:border-secondary-700 dark:bg-secondary-800 dark:text-white"
        required
        autocomplete="off"
      >
      <input
        type="text"
        maxlength="1"
        class="otp-input w-12 h-14 text-center text-2xl font-bold rounded-lg border border-secondary-300 bg-white text-secondary-900 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 dark:border-secondary-700 dark:bg-secondary-800 dark:text-white"
        required
        autocomplete="off"
      >
      <input
        type="text"
        maxlength="1"
        class="otp-input w-12 h-14 text-center text-2xl font-bold rounded-lg border border-secondary-300 bg-white text-secondary-900 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 dark:border-secondary-700 dark:bg-secondary-800 dark:text-white"
        required
        autocomplete="off"
      >
    </div>

    <!-- Hidden identifier field -->
    <input type="hidden" id="identifier" value="<%= typeof identifier !== 'undefined' ? identifier : '' %>">

    <!-- Timer -->
    <div class="text-center">
      <p class="text-sm text-secondary-600 dark:text-secondary-400">
        Didn't receive code?
        <button
          type="button"
          id="resend-btn"
          class="font-medium text-primary-600 hover:text-primary-700 dark:text-primary-400 disabled:opacity-50 disabled:cursor-not-allowed"
          disabled
        >
          Request new code
          <span id="timer" class="ml-1">(2:00)</span>
        </button>
      </p>
    </div>

    <!-- Error Message -->
    <div id="error-message" class="hidden alert alert-error">
      <i data-feather="alert-circle" class="h-5 w-5"></i>
      <span id="error-text"></span>
    </div>

    <!-- Submit Button -->
    <button type="submit" class="btn-primary w-full" id="submit-btn">
      <span class="btn-text">Verify Code</span>
      <span class="hidden">
        <svg class="animate-spin h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        Verifying...
      </span>
    </button>
  </form>

  <!-- Back to Login -->
  <p class="mt-8 text-center text-sm text-secondary-600 dark:text-secondary-400">
    <a href="/signin" class="font-medium text-primary-600 hover:text-primary-700 dark:text-primary-400">
      Back to Sign In
    </a>
  </p>
</div>

<style>
  .otp-input {
    text-align: center;
    letter-spacing: 0.1em;
  }

  .otp-input:focus {
    outline: none;
    border-color: #4f46e5;
    box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.1);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const otpInputs = document.querySelectorAll('.otp-input');
    const otpForm = document.getElementById('otp-form');
    const submitBtn = document.getElementById('submit-btn');
    const btnText = submitBtn.querySelector('.btn-text');
    const btnLoading = submitBtn.querySelector('span:last-child');
    const errorMessage = document.getElementById('error-message');
    const errorText = document.getElementById('error-text');
    const resendBtn = document.getElementById('resend-btn');
    const timer = document.getElementById('timer');

    let timeLeft = 120; // 2 minutes in seconds

    // OTP input handling
    otpInputs.forEach((input, index) => {
      // Handle input
      input.addEventListener('input', function(e) {
        const value = e.target.value;

        // Only allow numbers
        e.target.value = value.replace(/[^0-9]/g, '');

        // Auto-focus next input
        if (e.target.value.length === 1 && index < otpInputs.length - 1) {
          otpInputs[index + 1].focus();
        }
      });

      // Handle backspace
      input.addEventListener('keydown', function(e) {
        if (e.key === 'Backspace' && !e.target.value && index > 0) {
          otpInputs[index - 1].focus();
        }
      });

      // Handle paste
      input.addEventListener('paste', function(e) {
        e.preventDefault();
        const pastedData = e.clipboardData.getData('text').slice(0, 6);

        otpInputs.forEach((otpInput, i) => {
          if (pastedData[i]) {
            otpInput.value = pastedData[i];
          }
        });

        // Focus the last filled input
        const lastIndex = Math.min(pastedData.length, otpInputs.length) - 1;
        if (lastIndex >= 0) {
          otpInputs[lastIndex].focus();
        }
      });
    });

    // Timer countdown
    const timerInterval = setInterval(() => {
      timeLeft--;
      const minutes = Math.floor(timeLeft / 60);
      const seconds = timeLeft % 60;
      timer.textContent = `(${minutes}:${seconds.toString().padStart(2, '0')})`;

      if (timeLeft <= 0) {
        clearInterval(timerInterval);
        resendBtn.disabled = false;
        timer.textContent = '';
      }
    }, 1000);

    // Resend code
    resendBtn.addEventListener('click', function() {
      const identifier = document.getElementById('identifier').value;

      if (!identifier) {
        errorText.textContent = 'Identifier is missing. Please try again from the forgot password page.';
        errorMessage.classList.remove('hidden');
        return;
      }

      // Reset timer
      timeLeft = 120;
      resendBtn.disabled = true;

      // Resend OTP
      fetch('/send-otp', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: `identifier=${encodeURIComponent(identifier)}`
      })
      .then(response => response.text())
      .then(data => {
        if (!data.includes('Error') && !data.includes('failed')) {
          Swal.fire({
            icon: 'success',
            title: 'Code Resent',
            text: 'A new verification code has been sent.',
            timer: 2000,
            showConfirmButton: false
          });
        } else {
          errorText.textContent = 'Failed to resend code. Please try again.';
          errorMessage.classList.remove('hidden');
        }
      })
      .catch(error => {
        errorText.textContent = 'An error occurred. Please try again.';
        errorMessage.classList.remove('hidden');
      });
    });

    // Form submission
    otpForm.addEventListener('submit', function(e) {
      e.preventDefault();

      // Collect OTP
      let otp = '';
      otpInputs.forEach(input => {
        otp += input.value;
      });

      if (otp.length !== 6) {
        errorText.textContent = 'Please enter all 6 digits of the verification code.';
        errorMessage.classList.remove('hidden');
        return;
      }

      // Show loading state
      btnText.classList.add('hidden');
      btnLoading.classList.remove('hidden');
      submitBtn.disabled = true;
      errorMessage.classList.add('hidden');

      const identifier = document.getElementById('identifier').value;

      fetch('/verify-otp', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          identifier: identifier,
          otp: otp
        })
      })
      .then(response => response.text())
      .then(data => {
        if (data.includes('newpass') || !data.includes('Invalid')) {
          // Success - redirect to new password page
          window.location.href = '/newPass?identifier=' + encodeURIComponent(identifier);
        } else {
          // Show error
          errorText.textContent = 'Invalid or expired code. Please try again.';
          errorMessage.classList.remove('hidden');

          // Reset button
          btnText.classList.remove('hidden');
          btnLoading.classList.add('hidden');
          submitBtn.disabled = false;

          // Clear OTP inputs
          otpInputs.forEach(input => input.value = '');
          otpInputs[0].focus();
        }
      })
      .catch(error => {
        errorText.textContent = 'An error occurred. Please try again.';
        errorMessage.classList.remove('hidden');

        btnText.classList.remove('hidden');
        btnLoading.classList.add('hidden');
        submitBtn.disabled = false;
      });
    });

    // Focus first input on load
    otpInputs[0].focus();
  });
</script>
