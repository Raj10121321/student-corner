<%-
layout('auth-layout', {
  title: 'Forgot Password - Student Corner',
  heading: 'Reset Password',
  subheading: 'Enter your email or phone number to receive a verification code.'
})
-%>

<div class="animate-fade-in">
  <!-- Form Header -->
  <div class="mb-8 text-center">
    <h2 class="text-2xl font-bold text-secondary-900 dark:text-white">Forgot Password?</h2>
    <p class="mt-2 text-sm text-secondary-600 dark:text-secondary-400">
      No worries, we'll send you reset instructions
    </p>
  </div>

  <!-- OTP Send Form -->
  <form id="otp-form" class="space-y-5">
    <!-- Email/Phone Input -->
    <div class="input-floating">
      <input
        type="text"
        id="identifier"
        name="identifier"
        placeholder=" "
        required
      >
      <label for="identifier">Email Address or Phone Number</label>
    </div>

    <!-- Error Message -->
    <div id="error-message" class="hidden alert alert-error">
      <i data-feather="alert-circle" class="h-5 w-5"></i>
      <span id="error-text"></span>
    </div>

    <!-- Success Message -->
    <div id="success-message" class="hidden alert alert-success">
      <i data-feather="check-circle" class="h-5 w-5"></i>
      <span id="success-text"></span>
    </div>

    <!-- Submit Button -->
    <button type="submit" class="btn-primary w-full" id="submit-btn">
      <span class="btn-text">Send Reset Code</span>
      <span class="hidden">
        <svg class="animate-spin h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        Sending...
      </span>
    </button>
  </form>

  <!-- Back to Login -->
  <p class="mt-8 text-center text-sm text-secondary-600 dark:text-secondary-400">
    Remember your password?
    <a href="/signin" class="font-medium text-primary-600 hover:text-primary-700 dark:text-primary-400">
      Sign in
    </a>
  </p>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const otpForm = document.getElementById('otp-form');
    const submitBtn = document.getElementById('submit-btn');
    const btnText = submitBtn.querySelector('.btn-text');
    const btnLoading = submitBtn.querySelector('span:last-child');
    const errorMessage = document.getElementById('error-message');
    const errorText = document.getElementById('error-text');
    const successMessage = document.getElementById('success-message');
    const successText = document.getElementById('success-text');

    // Form submission
    otpForm.addEventListener('submit', function(e) {
      e.preventDefault();

      // Hide previous messages
      errorMessage.classList.add('hidden');
      successMessage.classList.add('hidden');

      // Show loading state
      btnText.classList.add('hidden');
      btnLoading.classList.remove('hidden');
      submitBtn.disabled = true;

      const identifier = document.getElementById('identifier').value;

      fetch('/send-otp', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: `identifier=${encodeURIComponent(identifier)}`
      })
      .then(response => response.text())
      .then(data => {
        if (!data.includes('Error') && !data.includes('failed') && !data.includes('No such')) {
          // Success - redirect to OTP page or show success
          if (data.includes('<!DOCTYPE') || data.includes('<html')) {
            // Server returned HTML page (OTP page), extract redirect
            const parser = new DOMParser();
            const doc = parser.parseFromString(data, 'text/html');
            // If it's a redirect, go to OTP page
            window.location.href = '/otp?identifier=' + encodeURIComponent(identifier);
          } else {
            // Show success message
            successText.textContent = 'Reset code sent successfully! Check your email or phone.';
            successMessage.classList.remove('hidden');

            // Reset button
            btnText.classList.remove('hidden');
            btnLoading.classList.add('hidden');
            submitBtn.disabled = false;

            // Redirect after delay
            setTimeout(() => {
              window.location.href = '/otp?identifier=' + encodeURIComponent(identifier);
            }, 2000);
          }
        } else {
          // Show error
          errorText.textContent = data || 'Failed to send reset code. Please try again.';
          errorMessage.classList.remove('hidden');

          // Reset button
          btnText.classList.remove('hidden');
          btnLoading.classList.add('hidden');
          submitBtn.disabled = false;
        }
      })
      .catch(error => {
        errorText.textContent = 'An error occurred. Please try again.';
        errorMessage.classList.remove('hidden');

        btnText.classList.remove('hidden');
        btnLoading.classList.add('hidden');
        submitBtn.disabled = false;
      });
    });
  });
</script>
