<%-
layout('admin-layout', {
  title: 'Manage Events - Admin Panel',
  currentPath: '/admin/events',
  pageTitle: 'Events',
  admin: typeof admin !== 'undefined' ? admin : null
})
-%>

<!-- Events Management Header -->
<div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
  <div>
    <h1 class="text-2xl font-bold text-secondary-900 dark:text-white">Event Management</h1>
    <p class="mt-1 text-sm text-secondary-600 dark:text-secondary-400">
      Create and manage all events on the platform
    </p>
  </div>

  <div class="flex items-center gap-3">
    <button onclick="exportEvents()" class="btn-secondary inline-flex items-center gap-2">
      <i data-feather="download" class="h-4 w-4"></i>
      Export
    </button>
    <a href="/admin/events/add" class="btn-primary inline-flex items-center gap-2">
      <i data-feather="plus-circle" class="h-4 w-4"></i>
      Add Event
    </a>
  </div>
</div>

<!-- Stats Overview -->
<div class="grid gap-6 sm:grid-cols-3 mb-8">
  <div class="card p-6">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm font-medium text-secondary-600 dark:text-secondary-400">Total Events</p>
        <p class="mt-2 text-3xl font-bold text-secondary-900 dark:text-white">
          <%= typeof events !== 'undefined' ? events.length : 0 %>
        </p>
      </div>
      <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary-100 text-primary-600 dark:bg-primary-900/30">
        <i data-feather="calendar" class="h-6 w-6"></i>
      </div>
    </div>
  </div>

  <div class="card p-6">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm font-medium text-secondary-600 dark:text-secondary-400">Active Events</p>
        <p class="mt-2 text-3xl font-bold text-secondary-900 dark:text-white">
          <%= typeof events !== 'undefined' ? events.filter(e => e.status === 'active').length : 0 %>
        </p>
      </div>
      <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-accent-success/10 text-accent-success">
        <i data-feather="check-circle" class="h-6 w-6"></i>
      </div>
    </div>
  </div>

  <div class="card p-6">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm font-medium text-secondary-600 dark:text-secondary-400">Past Events</p>
        <p class="mt-2 text-3xl font-bold text-secondary-900 dark:text-white">
          <%= typeof events !== 'undefined' ? events.filter(e => e.status === 'past').length : 0 %>
        </p>
      </div>
      <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-accent-warning/10 text-accent-warning">
        <i data-feather="archive" class="h-6 w-6"></i>
      </div>
    </div>
  </div>
</div>

<!-- Search and Filter -->
<div class="card mb-6">
  <div class="p-6">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <!-- Search -->
      <div class="relative flex-1 max-w-md">
        <i data-feather="search" class="absolute left-3 top-1/2 h-5 w-5 -translate-y-1/2 text-secondary-400"></i>
        <input
          type="text"
          id="event-search"
          placeholder="Search events by name..."
          class="input-field pl-10"
        >
      </div>

      <!-- Filters -->
      <div class="flex items-center gap-3">
        <select id="status-filter" class="input-field w-32">
          <option value="all">All Status</option>
          <option value="active">Active</option>
          <option value="past">Past</option>
        </select>

        <select id="sort-events" class="input-field w-40">
          <option value="newest">Newest First</option>
          <option value="oldest">Oldest First</option>
          <option value="name">Name A-Z</option>
          <option value="deadline">Deadline</option>
        </select>
      </div>
    </div>
  </div>
</div>

<!-- Events Grid -->
<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 mb-8">
  <% if (typeof events !== 'undefined' && events.length > 0) { %>
    <% events.forEach((event, index) => { %>
      <div class="card">
        <div class="relative h-48">
          <img src="<%= event.logo || event.img || '/images/placeholder-event.jpg' %>" alt="<%= event.eventname %>" class="h-full w-full object-cover">
          <div class="absolute top-3 right-3">
            <span class="badge <%= event.status === 'active' ? 'badge-success' : 'badge-warning' %>">
              <%= event.status === 'active' ? 'Active' : 'Past' %>
            </span>
          </div>
        </div>

        <div class="p-5">
          <h3 class="mb-2 font-semibold text-secondary-900 dark:text-white line-clamp-1">
            <%= event.eventname %>
          </h3>

          <div class="mb-4 space-y-2 text-sm text-secondary-600 dark:text-secondary-400">
            <div class="flex items-center gap-2">
              <i data-feather="calendar" class="h-4 w-4"></i>
              <%= event.month && event.day ? event.month + ' ' + event.day : 'TBD' %>
            </div>
            <div class="flex items-center gap-2">
              <i data-feather="map-pin" class="h-4 w-4"></i>
              <%= event.location || 'TBD' %>
            </div>
          </div>

          <div class="flex items-center justify-between pt-4 border-t border-secondary-200 dark:border-secondary-800">
            <div class="flex gap-2">
              <button onclick="editEvent('<%= event.id %>')" class="btn-ghost p-2" title="Edit">
                <i data-feather="edit-2" class="h-4 w-4"></i>
              </button>
              <button onclick="deleteEvent('<%= event.id %>')" class="btn-ghost p-2 text-accent-error" title="Delete">
                <i data-feather="trash-2" class="h-4 w-4"></i>
              </button>
            </div>
            <a href="/event/<%= event.id %>" class="btn-primary text-sm">View</a>
          </div>
        </div>
      </div>
    <% }) %>
  <% } else { %>
    <!-- Empty State -->
    <div class="col-span-full py-16 text-center">
      <div class="mx-auto mb-6 flex h-20 w-20 items-center justify-center rounded-full bg-secondary-100 dark:bg-secondary-800">
        <i data-feather="calendar" class="h-10 w-10 text-secondary-400"></i>
      </div>
      <h3 class="text-xl font-semibold text-secondary-900 dark:text-white">No events found</h3>
      <p class="mt-2 text-secondary-600 dark:text-secondary-400">
        Create your first event to get started
      </p>
      <a href="/admin/events/add" class="btn-primary mt-6 inline-flex items-center gap-2">
        Add Event
        <i data-feather="plus" class="h-4 w-4"></i>
      </a>
    </div>
  <% } %>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Search functionality
    const searchInput = document.getElementById('event-search');
    searchInput.addEventListener('input', function() {
      const query = this.value.toLowerCase();
      const cards = document.querySelectorAll('.grid > div');

      cards.forEach(card => {
        const text = card.textContent.toLowerCase();
        card.style.display = text.includes(query) ? '' : 'none';
      });
    });

    // Status filter
    document.getElementById('status-filter').addEventListener('change', function() {
      const filter = this.value;
      const cards = document.querySelectorAll('.grid > div');

      cards.forEach(card => {
        if (filter === 'all') {
          card.style.display = '';
        } else {
          // Add status filtering logic based on badges
          const badge = card.querySelector('.badge');
          if (badge) {
            const status = badge.textContent.toLowerCase().includes(filter);
            card.style.display = status ? '' : 'none';
          }
        }
      });
    });
  });

  function editEvent(eventId) {
    Swal.fire({
      title: 'Edit Event',
      text: 'Edit event functionality will open the edit form',
      icon: 'info'
    });
  }

  function deleteEvent(eventId) {
    Swal.fire({
      title: 'Delete Event',
      text: 'Are you sure you want to delete this event? This action cannot be undone.',
      icon: 'warning',
      showCancelButton: true,
      confirmButtonText: 'Yes, delete',
      cancelButtonText: 'Cancel',
      confirmButtonColor: '#ef4444',
      cancelButtonColor: '#64748b',
    }).then((result) => {
      if (result.isConfirmed) {
        fetch('/admin/events/' + eventId + '/delete', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' }
        })
        .then(response => response.json())
        .then(data => {
          if (data.success) {
            Swal.fire({
              icon: 'success',
              title: 'Deleted!',
              text: 'Event has been deleted successfully.',
              timer: 2000,
              showConfirmButton: false
            }).then(() => location.reload());
          } else {
            Swal.fire('Error', data.message || 'Failed to delete event', 'error');
          }
        });
      }
    });
  }

  function exportEvents() {
    Swal.fire({
      title: 'Export Events',
      text: 'Export functionality will be implemented soon',
      icon: 'info'
    });
  }
</script>
