<%-
layout('main-layout', {
  title: 'Hackathons - Student Corner',
  currentPath: '/hackathons'
})
-%>

<!-- Hackathons Header with Special Design -->
<div class="relative overflow-hidden bg-gradient-to-br from-purple-900 via-indigo-900 to-purple-900">
  <!-- Animated Background -->
  <div class="absolute inset-0">
    <div class="absolute top-0 left-1/4 h-96 w-96 rounded-full bg-purple-500/20 blur-3xl animate-pulse-slow"></div>
    <div class="absolute bottom-0 right-1/4 h-96 w-96 rounded-full bg-indigo-500/20 blur-3xl animate-pulse-slow" style="animation-delay: 1s;"></div>
  </div>

  <div class="relative section py-16">
    <div class="text-center">
      <!-- Badge -->
      <div class="mb-6 inline-flex">
        <span class="badge bg-white/10 text-white border-white/20">
          <i data-feather="code" class="mr-2 h-4 w-4"></i>
          Build. Innovate. Win.
        </span>
      </div>

      <h1 class="text-5xl font-bold text-white sm:text-6xl lg:text-7xl">
        Discover
        <span class="bg-gradient-to-r from-purple-400 via-pink-400 to-purple-400 bg-clip-text text-transparent animate-gradient-xy">
          Hackathons
        </span>
      </h1>

      <p class="mt-6 text-xl text-purple-100 max-w-2xl mx-auto">
        Join exciting coding challenges, compete with developers worldwide, and win amazing prizes
      </p>

      <!-- Stats -->
      <div class="mt-12 grid grid-cols-2 gap-8 sm:grid-cols-4">
        <div class="text-center">
          <div class="text-3xl font-bold text-white">50+</div>
          <div class="text-sm text-purple-200">Active Hackathons</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-white">$100K+</div>
          <div class="text-sm text-purple-200">Total Prizes</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-white">10K+</div>
          <div class="text-sm text-purple-200">Participants</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-white">500+</div>
          <div class="text-sm text-purple-200">Projects Built</div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Hackathons Content -->
<div class="section py-8">
  <!-- Search and Filters -->
  <div class="mb-8">
    <%- include('../partials/components/search-bar', {
      placeholder: 'Search hackathons by name, location, or tech stack...',
      filters: true,
      filterOptions: [
        { name: 'date', label: 'Date', options: ['This Week', 'This Month', 'This Year'] },
        { name: 'prize', label: 'Prize Pool', options: ['$1K+', '$5K+', '$10K+', '$50K+'] },
        { name: 'location', label: 'Location', options: ['Online', 'In-Person', 'Hybrid'] },
        { name: 'tech', label: 'Tech Stack', options: ['Web3', 'AI/ML', 'Mobile', 'Cloud'] }
      ]
    }) %>
  </div>

  <!-- Hackathon Categories -->
  <div class="mb-8 flex flex-wrap gap-3">
    <button class="btn-primary text-sm">All Hackathons</button>
    <button class="btn-ghost text-sm">🏆 Prize-based</button>
    <button class="btn-ghost text-sm">💻 Online</button>
    <button class="btn-ghost text-sm">🎯 Beginner Friendly</button>
    <button class="btn-ghost text-sm">🚀 Innovation</button>
    <button class="btn-ghost text-sm">🤖 AI/ML</button>
  </div>

  <!-- View Toggle and Sort -->
  <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div class="flex items-center gap-4">
      <p class="text-sm text-secondary-600 dark:text-secondary-400">
        Showing <span class="font-semibold text-secondary-900 dark:text-white" id="hackathons-count">
          <%= typeof upcomingHackthons !== 'undefined' ? upcomingHackthons.length : 0 %>
        </span>
        hackathons
      </p>
    </div>

    <div class="flex items-center gap-3">
      <!-- Sort -->
      <select id="sort-select" class="input-field w-48">
        <option value="deadline">Sort by Deadline</option>
        <option value="prize">Sort by Prize</option>
        <option value="date">Sort by Date</option>
        <option value="popularity">Sort by Popularity</option>
      </select>
    </div>
  </div>

  <!-- Featured Hackathon (if available) -->
  <% if (typeof upcomingHackthons !== 'undefined' && upcomingHackthons.length > 0) { %>
    <div class="mb-12 card overflow-hidden bg-gradient-to-br from-purple-600 to-indigo-600 text-white">
      <div class="grid items-center gap-8 p-8 lg:grid-cols-2">
        <div>
          <span class="badge bg-white/20 text-white border-white/30 mb-4">⭐ Featured Hackathon</span>
          <h2 class="text-3xl font-bold mb-4">
            <%= upcomingHackthons[0].eventName || upcomingHackthons[0].eventname %>
          </h2>
          <p class="text-purple-100 mb-6 line-clamp-2">
            <%= upcomingHackthons[0].description || 'An exciting hackathon with amazing prizes and learning opportunities.' %>
          </p>

          <div class="grid grid-cols-2 gap-4 mb-6">
            <div class="flex items-center gap-2">
              <i data-feather="calendar" class="h-5 w-5"></i>
              <span><%= upcomingHackthons[0].month %> <%= upcomingHackthons[0].day %></span>
            </div>
            <div class="flex items-center gap-2">
              <i data-feather="map-pin" class="h-5 w-5"></i>
              <span><%= upcomingHackthons[0].location %></span>
            </div>
            <div class="flex items-center gap-2">
              <i data-feather="users" class="h-5 w-5"></i>
              <span><%= upcomingHackthons[0].age || 'All ages' %></span>
            </div>
            <div class="flex items-center gap-2">
              <i data-feather="award" class="h-5 w-5"></i>
              <span>$10,000+ Prizes</span>
            </div>
          </div>

          <div class="flex gap-4">
            <a href="/hackathon/<%= upcomingHackthons[0].id %>" class="btn-secondary bg-white/10 text-white border-white/20 hover:bg-white/20 flex-1 text-center">
              View Details
            </a>
            <button onclick="enroll('<%= upcomingHackthons[0].id %>', 'hackathon')" class="btn-primary bg-white text-purple-600 hover:bg-purple-50 flex-1" <%= upcomingHackthons[0].status !== 'active' ? 'disabled' : '' %>>
              Register Now
            </button>
          </div>
        </div>

        <div class="relative h-64 lg:h-auto">
          <img src="<%= upcomingHackthons[0].img || upcomingHackthons[0].logo || '/images/placeholder-hackathon.jpg' %>" alt="<%= upcomingHackthons[0].eventName %>" class="h-full w-full object-cover rounded-lg">
          <div class="absolute top-4 right-4">
            <span class="badge badge-success">Registration Open</span>
          </div>
        </div>
      </div>
    </div>
  <% } %>

  <!-- Hackathons Grid -->
  <div id="hackathons-container" class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    <% if (typeof upcomingHackthons !== 'undefined' && upcomingHackthons.length > 0) { %>
      <% upcomingHackthons.forEach((hackathon, index) => { %>
        <%- include('../partials/components/event-card', {
          event: hackathon,
          type: 'hackathon',
          isEnrolled: hackathon.isEnrolled || false,
          showEnrollButton: true
        }) %>
      <% }) %>
    <% } else { %>
      <!-- Empty State -->
      <div class="col-span-full py-16 text-center">
        <div class="mx-auto mb-6 flex h-24 w-24 items-center justify-center rounded-full bg-secondary-100 dark:bg-secondary-800">
          <i data-feather="code" class="h-12 w-12 text-secondary-400"></i>
        </div>
        <h3 class="text-xl font-semibold text-secondary-900 dark:text-white">No hackathons found</h3>
        <p class="mt-2 text-secondary-600 dark:text-secondary-400">
          Check back later for new hackathon announcements
        </p>
      </div>
    <% } %>
  </div>
</div>

<!-- Why Participate Section -->
<section class="border-t border-secondary-200 bg-secondary-50 py-16 dark:border-secondary-800 dark:bg-secondary-900/50">
  <div class="section">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-secondary-900 dark:text-white sm:text-4xl">
        Why Participate in
        <span class="text-gradient">Hackathons?</span>
      </h2>
    </div>

    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-4">
      <div class="card p-6 text-center">
        <div class="mb-4 inline-flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-purple-500 to-indigo-500 text-white">
          <i data-feather="trophy" class="h-8 w-8"></i>
        </div>
        <h3 class="mb-2 text-lg font-semibold text-secondary-900 dark:text-white">Win Prizes</h3>
        <p class="text-sm text-secondary-600 dark:text-secondary-400">
          Compete for cash prizes, gadgets, and career opportunities
        </p>
      </div>

      <div class="card p-6 text-center">
        <div class="mb-4 inline-flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-primary-500 to-purple-500 text-white">
          <i data-feather="users" class="h-8 w-8"></i>
        </div>
        <h3 class="mb-2 text-lg font-semibold text-secondary-900 dark:text-white">Build Network</h3>
        <p class="text-sm text-secondary-600 dark:text-secondary-400">
          Connect with talented developers and industry leaders
        </p>
      </div>

      <div class="card p-6 text-center">
        <div class="mb-4 inline-flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-indigo-500 to-blue-500 text-white">
          <i data-feather="code" class="h-8 w-8"></i>
        </div>
        <h3 class="mb-2 text-lg font-semibold text-secondary-900 dark:text-white">Learn Skills</h3>
        <p class="text-sm text-secondary-600 dark:text-secondary-400">
          Gain hands-on experience with latest technologies
        </p>
      </div>

      <div class="card p-6 text-center">
        <div class="mb-4 inline-flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-pink-500 to-purple-500 text-white">
          <i data-feather="briefcase" class="h-8 w-8"></i>
        </div>
        <h3 class="mb-2 text-lg font-semibold text-secondary-900 dark:text-white">Get Hired</h3>
        <p class="text-sm text-secondary-600 dark:text-secondary-400">
          Showcase your talent to potential employers and sponsors
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Category filter buttons
    const categoryButtons = document.querySelectorAll('.mb-8.flex button');
    categoryButtons.forEach(button => {
      button.addEventListener('click', function() {
        // Update active state
        categoryButtons.forEach(btn => {
          btn.classList.remove('btn-primary');
          btn.classList.add('btn-ghost');
        });
        this.classList.remove('btn-ghost');
        this.classList.add('btn-primary');

        // Filter hackathons (visual feedback)
        const filterType = this.textContent.trim();
        console.log('Filtering by:', filterType);
        // In a real app, this would filter the hackathons
      });
    });

    // Sort functionality
    const sortSelect = document.getElementById('sort-select');
    if (sortSelect) {
      sortSelect.addEventListener('change', function() {
        const sortBy = this.value;
        console.log('Sorting by:', sortBy);
        // In a real app, this would sort the hackathons
      });
    }
  });
</script>
