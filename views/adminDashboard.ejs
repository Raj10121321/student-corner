<!DOCTYPE html>
<html class="dark" lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Console | TechNexus</title>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
    body { background-color: #0b1326; color: #dae2fd; }
    .glass-card { background: rgba(30, 41, 59, 0.7); backdrop-filter: blur(12px); border: 1px solid #334155; }
    .chart-bar { transition: height 1s ease-out; }
  </style>
  <script>
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            "primary": "#c0c1ff", "on-primary": "#1000a9", "primary-container": "#8083ff",
            "secondary": "#adc6ff", "secondary-container": "#0566d9",
            "tertiary": "#4edea3", "tertiary-container": "#00885d",
            "error": "#ffb4ab", "error-container": "#93000a",
            "background": "#0b1326", "on-background": "#dae2fd",
            "surface": "#0b1326", "on-surface": "#dae2fd",
            "surface-container": "#171f33", "surface-container-highest": "#2d3449",
            "outline": "#908fa0", "outline-variant": "#464554"
          },
          borderRadius: { "DEFAULT": "0.125rem", "lg": "0.25rem", "xl": "0.5rem" },
          spacing: { "gutter": "24px", "stack-md": "16px", "stack-lg": "32px" },
          fontFamily: { "body-md": ["Inter"], "headline-lg": ["Inter"], "label-mono": ["JetBrains Mono"] },
          fontSize: { "body-md": ["16px", { "lineHeight": "24px" }], "headline-lg": ["32px", { "lineHeight": "40px" }], "label-mono": ["13px", { "lineHeight": "16px" }] }
        }
      }
    }
  </script>
</head>

<body class="flex min-h-screen">
  <!-- Sidebar -->
  <aside class="fixed left-0 top-0 h-full flex flex-col py-6 bg-surface-container border-r border-outline-variant w-60 z-50">
    <div class="px-6 mb-8">
      <h1 class="font-headline-md text-primary mb-1">Admin Panel</h1>
      <p class="font-label-mono text-on-surface-variant text-xs">Management Suite</p>
    </div>
    <nav class="flex-1 px-4 space-y-2">
      <a class="flex items-center gap-3 bg-secondary-container text-on-secondary-container rounded-lg px-4 py-2" href="/admin/dashboard">
        <span class="material-symbols-outlined">dashboard</span> Dashboard
      </a>
      <a class="flex items-center gap-3 text-on-surface-variant hover:bg-surface-variant px-4 py-2 rounded-lg transition-colors" href="/admin/users">
        <span class="material-symbols-outlined">group</span> Users
      </a>
      <a class="flex items-center gap-3 text-on-surface-variant hover:bg-surface-variant px-4 py-2 rounded-lg transition-colors" href="/admin/events">
        <span class="material-symbols-outlined">calendar_today</span> Events
      </a>
      <a class="flex items-center gap-3 text-on-surface-variant hover:bg-surface-variant px-4 py-2 rounded-lg transition-colors" href="/admin/hackathons">
        <span class="material-symbols-outlined">code</span> Hackathons
      </a>
    </nav>
    <div class="px-4">
      <button class="w-full py-3 bg-primary text-on-primary rounded-xl font-button-text hover:opacity-90">Create New</button>
    </div>
    <div class="px-4 pt-6 border-t border-outline-variant space-y-2">
      <a class="flex items-center gap-3 text-on-surface-variant hover:text-primary px-4 py-2" href="#"><span class="material-symbols-outlined">settings</span> Settings</a>
      <a class="flex items-center gap-3 text-error hover:text-error/80 px-4 py-2" href="/admin/logout"><span class="material-symbols-outlined">logout</span> Logout</a>
    </div>
  </aside>

  <!-- Main Content -->
  <main class="flex-1 ml-60 flex flex-col">
    <!-- Top Bar -->
    <header class="flex justify-between items-center w-full px-6 h-14 bg-surface-container-highest shadow-sm sticky top-0 z-40">
      <div class="flex items-center gap-4">
        <input class="bg-surface-dim border-none rounded-lg px-4 py-1.5 text-sm w-64 focus:ring-1 focus:ring-primary" placeholder="Search resources..." type="text"/>
      </div>
      <div class="flex items-center gap-6">
        <button class="p-2 rounded-full hover:bg-surface-bright transition-all"><span class="material-symbols-outlined">notifications</span></button>
        <div class="flex items-center gap-3 pl-4 border-l border-outline-variant">
          <p class="font-label-mono text-on-surface">Admin</p>
          <div class="w-8 h-8 rounded-full bg-primary/20 flex items-center justify-center text-primary text-sm font-bold">A</div>
        </div>
      </div>
    </header>

    <!-- Dashboard Content -->
    <div class="p-8 space-y-8">
      <div class="flex flex-col gap-1">
        <h2 class="font-headline-lg text-on-surface">Platform Overview</h2>
        <p class="text-on-surface-variant">Real-time metrics and system status</p>
      </div>

      <!-- Stats Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="glass-card p-6 rounded-xl flex flex-col justify-between h-40">
          <div class="flex justify-between items-start">
            <div class="p-2 bg-primary/10 rounded-lg text-primary"><span class="material-symbols-outlined">group</span></div>
            <span class="text-tertiary font-label-mono text-xs">Active</span>
          </div>
          <div>
            <p class="text-on-surface-variant font-label-mono text-xs uppercase">Total Users</p>
            <h3 class="text-headline-md text-on-surface"><%= userCount %></h3>
          </div>
        </div>

        <div class="glass-card p-6 rounded-xl flex flex-col justify-between h-40">
          <div class="flex justify-between items-start">
            <div class="p-2 bg-secondary/10 rounded-lg text-secondary"><span class="material-symbols-outlined">event_available</span></div>
            <span class="text-on-surface-variant font-label-mono text-xs">Total</span>
          </div>
          <div>
            <p class="text-on-surface-variant font-label-mono text-xs uppercase">Total Events</p>
            <h3 class="text-headline-md text-on-surface"><%= eventCount %></h3>
          </div>
        </div>

        <div class="glass-card p-6 rounded-xl flex flex-col justify-between h-40">
          <div class="flex justify-between items-start">
            <div class="p-2 bg-tertiary/10 rounded-lg text-tertiary"><span class="material-symbols-outlined">terminal</span></div>
            <span class="text-tertiary font-label-mono text-xs">Total</span>
          </div>
          <div>
            <p class="text-on-surface-variant font-label-mono text-xs uppercase">Hackathons</p>
            <h3 class="text-headline-md text-on-surface"><%= hackathonCount %></h3>
          </div>
        </div>

        <div class="glass-card p-6 rounded-xl flex flex-col justify-between h-40">
          <div class="flex justify-between items-start">
            <div class="p-2 bg-error/10 rounded-lg text-error"><span class="material-symbols-outlined">security</span></div>
            <span class="text-error font-label-mono text-xs">Monitor</span>
          </div>
          <div>
            <p class="text-on-surface-variant font-label-mono text-xs uppercase">System Status</p>
            <h3 class="text-headline-md text-on-surface">Online</h3>
          </div>
        </div>
      </div>

      <!-- Quick Actions -->
      <div class="glass-card rounded-xl overflow-hidden">
        <div class="px-8 py-6 border-b border-outline-variant flex justify-between items-center">
          <h4 class="font-headline-md text-on-surface">Quick Actions</h4>
        </div>
        <div class="p-8 grid grid-cols-2 md:grid-cols-4 gap-4">
          <a href="/admin/users/add" class="tonal-layer-1 rounded-lg p-4 text-center hover:border-primary transition-all">
            <span class="material-symbols-outlined text-primary text-2xl">person_add</span>
            <p class="text-sm font-medium mt-2">Add User</p>
          </a>
          <a href="/admin/events/add" class="tonal-layer-1 rounded-lg p-4 text-center hover:border-primary transition-all">
            <span class="material-symbols-outlined text-secondary text-2xl">event_add</span>
            <p class="text-sm font-medium mt-2">Add Event</p>
          </a>
          <a href="/admin/hackathons/add" class="tonal-layer-1 rounded-lg p-4 text-center hover:border-tertiary transition-all">
            <span class="material-symbols-outlined text-tertiary text-2xl">code</span>
            <p class="text-sm font-medium mt-2">Add Hackathon</p>
          </a>
          <a href="/admin/users" class="tonal-layer-1 rounded-lg p-4 text-center hover:border-error transition-all">
            <span class="material-symbols-outlined text-error text-2xl">manage_accounts</span>
            <p class="text-sm font-medium mt-2">Manage Users</p>
          </a>
        </div>
      </div>

      <!-- Recent Activity -->
      <div class="glass-card rounded-xl overflow-hidden">
        <div class="px-8 py-6 border-b border-outline-variant">
          <h4 class="font-headline-md text-on-surface">Recent Activity</h4>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-left text-sm">
            <thead class="bg-surface-container-high/50 text-on-surface-variant font-label-mono uppercase">
              <tr>
                <th class="px-8 py-4">User</th>
                <th class="px-8 py-4">Action</th>
                <th class="px-8 py-4">Time</th>
                <th class="px-8 py-4">Status</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-outline-variant">
              <tr class="hover:bg-surface-variant/20">
                <td class="px-8 py-4 font-medium">admin@technexus.com</td>
                <td class="px-8 py-4">System Login</td>
                <td class="px-8 py-4 text-on-surface-variant">Just now</td>
                <td class="px-8 py-4"><span class="px-2 py-1 rounded-full bg-tertiary/10 text-tertiary text-xs">Success</span></td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </main>
</body>
</html>